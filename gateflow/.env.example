DATABASE_URL=postgres://gateflow:123456@127.0.0.1:5432/gateflow

HTTP_LISTEN_ADDR=0.0.0.0:8080
ADMIN_GRPC_LISTEN_ADDR=0.0.0.0:50051
UDP_LISTEN_ADDR=0.0.0.0:8123

HMAC_GLOBAL_SALT=change-me
GW_TOKEN=change-me
RUST_LOG=info

DB_MAX_CONNECTIONS=10
DB_CONNECT_TIMEOUT_SECS=5
PROXY_TIMEOUT_SECS=30
DEFAULT_APP_RATE_LIMIT_RPS=100
RUN_MIGRATIONS_ON_BOOT=false
PERSIST_HEALTH_TO_DB=true
HEALTH_STATUS_TTL_SECS=120
HEALTH_CLEANUP_INTERVAL_SECS=30
SIGNATURE_REPLAY_WINDOW_SECS=60
